      "Source": "VFD_RUN_CMD, VFD_RUN_FB",
      "Basic trigger logic": "Run command active but drive run feedback does not become active after start delay."
    },
    {
      "Alarm tag": "MTR_x_UNEXPECTED_STOP_ALM",
      "Alarm message": "Motor stopped unexpectedly",
      "Mandatory": "Yes",
      "Source": "VFD_RUN_CMD, VFD_RUN_FB",
      "Basic trigger logic": "Run command still required but drive run feedback drops without stop request."
